---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  /** Absolute or root-relative path to a share image. Optional. */
  cover?: string;
  /** 'website' for the index, 'article' for posts. */
  type?: 'website' | 'article';
  /** ISO date string, articles only. */
  published?: string;
}

const { title, description, cover, type = 'website', published } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const coverURL = cover ? new URL(cover, Astro.site).href : undefined;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Moala Global — Insights" href={new URL('rss.xml', Astro.site)} />
  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- Open Graph: makes shared links render proper preview cards (D27 build spec) -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content={type} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Moala Global — Insights" />
  {coverURL && <meta property="og:image" content={coverURL} />}
  {type === 'article' && published && <meta property="article:published_time" content={published} />}
  <meta name="twitter:card" content={coverURL ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {coverURL && <meta name="twitter:image" content={coverURL} />}

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,600;0,700;1,500&family=Jost:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <header class="nav">
    <a class="wordmark" href="https://moalaglobal.com">Moala <span>Global</span></a>
    <nav class="menu">
      <a href="https://moalaglobal.com">Home</a>
      <a href="https://moalaglobal.com/#services">Services</a>
      <a href="/" class="active">Insights</a>
      <a href="https://moalaglobal.com/#about">About</a>
      <a href="https://moalaglobal.com/#contact">Contact</a>
    </nav>
  </header>

  <slot />

  <footer class="site">
    <span>Moala Global · International advisory</span>
    <span>GEDSI · Political economy · Evidence synthesis</span>
  </footer>
</body>
</html>
